    MONGO_ROOT_PASSWORD: <secure password - generate>
    REDIS_PASSWORD: <secure password - generate>
    # AI Provider API Keys (add as needed)
    OPENAI_API_KEY: <your-openai-api-key>
    ANTHROPIC_API_KEY: <your-anthropic-api-key>
